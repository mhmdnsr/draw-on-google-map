{
  "name": "draw-on-google-maps",
  "version": "2.0.0",
  "description": "Draw polygons, markers, polylines, circles, rectangles, and freehand strokes on Google Maps.",
  "main": "./dist/draw-on-google-map.umd.js",
  "module": "./dist/draw-on-google-map.es.js",
  "types": "./dist/types/index.d.ts",
  "unpkg": "./dist/draw-on-google-map.umd.js",
  "jsdelivr": "./dist/draw-on-google-map.umd.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/draw-on-google-map.es.js",
      "require": "./dist/draw-on-google-map.umd.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "RELEASE_NOTES.md",
    "LICENSE"
  ],
  "author": "Mohamed Nasr",
  "homepage": "http://drawonmap.mohamed-nsr.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhmdnsr/draw-on-google-map.git"
  },
  "keywords": [
    "draw",
    "draw on map",
    "google maps",
    "draw on google maps"
  ],
  "bugs": {
    "url": "https://github.com/mhmdnsr/draw-on-google-map/issues"
  },
  "devDependencies": {
    "@types/google.maps": "^3.58.1",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.7"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "audit": "npm audit --omit=dev --audit-level=high",
    "prepublishOnly": "npm run test && npm run build"
  },
  "type": "module",
  "sideEffects": false
}
